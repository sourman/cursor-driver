#!/usr/bin/env node
'use strict';
/*
 * cursor-netmon — capture network traffic from Cursor's workbench renderer via
 * CDP, to see what request (if any) the UI fires when a setting is toggled.
 * Cursor must be running with --remote-debugging-port=9223.
 *
 *   cursor-netmon [duration_seconds=60]
 *
 * Prints requests (method/url/postData) and WebSocket frames with a relative
 * millisecond timeline. Node 22+ globals only.
 */
const PORT = parseInt(process.env.CURSOR_CDP_PORT || '9223', 10);
const durSec = parseInt(process.argv[2] || '60', 10);

async function main() {
  const targets = await (await fetch(`http://127.0.0.1:${PORT}/json/list`)).json();
  const pages = targets.filter((t) => t.type === 'page');
  const tgt = pages.find((t) => /workbench/i.test(t.url)) || pages[0];
  if (!tgt) { console.error('no page target'); process.exit(1); }
  console.error(`# monitoring: ${(tgt.title || '').slice(0, 40)}  ${tgt.url}`);

  const ws = new WebSocket(tgt.webSocketDebuggerUrl);
  let nextId = 1;
  const pending = new Map();
  const start = Date.now();
  let count = 0;

  const ts = () => `+${String(Date.now() - start).padStart(6)}ms`;

  ws.addEventListener('message', (ev) => {
    let d; try { d = JSON.parse(ev.data); } catch (_) { return; }
    if (d.id && pending.has(d.id)) {
      const { resolve } = pending.get(d.id); pending.delete(d.id); resolve(d.result); return;
    }
    if (!d.method) return;
    if (d.method === 'Network.requestWillBeSent') {
      const r = d.params.request; count++;
      const pd = r.postData ? `\n             POSTDATA: ${r.postData.slice(0, 500)}` : '';
      console.log(`${ts()} REQ ${r.method} [${r.type}] ${r.url}${pd}`);
    } else if (d.method === 'Network.webSocketCreated') {
      count++; console.log(`${ts()} WS-OPEN  ${d.params.url}`);
    } else if (d.method === 'Network.webSocketFrameSent') {
      count++; console.log(`${ts()} WS-SEND  >>> ${String(d.params.response.payloadData || '').slice(0, 500)}`);
    } else if (d.method === 'Network.webSocketFrameReceived') {
      count++; console.log(`${ts()} WS-RECV  <<< ${String(d.params.response.payloadData || '').slice(0, 500)}`);
    } else if (d.method === 'Network.eventSourceMessageReceived') {
      count++; console.log(`${ts()} SSE ${d.params.eventName} ${String(d.params.data || '').slice(0, 200)}`);
    }
  });

  function call(method, params) {
    return new Promise((resolve, reject) => {
      const id = nextId++; pending.set(id, { resolve, reject });
      const pl = JSON.stringify({ id, method, params });
      if (ws.readyState === 1) ws.send(pl);
      else ws.addEventListener('open', () => ws.send(pl), { once: true });
    });
  }

  ws.addEventListener('open', async () => {
    try {
      await call('Network.enable');
      await call('Network.setCacheDisabled', { cacheDisabled: true });
      console.error(`# Network capture ON for ${durSec}s — FLIP THE TOGGLE IN CURSOR NOW (both ways).`);
    } catch (e) { console.error('enable failed:', e.message); }
  });
  ws.addEventListener('error', () => console.error('ws error'));

  setTimeout(async () => {
    console.error(`\n# done. ${count} network event(s) captured.`);
    try { await call('Network.disable'); } catch (_) {}
    try { ws.close(); } catch (_) {}
    process.exit(0);
  }, durSec * 1000);
}
main().catch((e) => { console.error('cursor-netmon:', e.message); process.exit(1); });
